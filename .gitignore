# Documentation
docs/

# Local .terraform directories
live/demo/*/.terraform/
**/.terraform/

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
*.tfvars.json

# Do not ignore .tfvars.example files, as they act as templates
!*.tfvars.example

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore tfplan files
*.tfplan
*tfplan*

# Ignore CLI configuration files
.terraformrc
terraform.rc

# macOS specific
.DS_Store