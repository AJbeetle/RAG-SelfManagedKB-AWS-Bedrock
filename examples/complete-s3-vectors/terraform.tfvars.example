region      = "us-east-1"
environment = "dev"
project     = "bedrock-kb"

s3_data_bucket_arn    = "arn:aws:s3:::replace-with-document-bucket"
s3_inclusion_prefixes = ["documents/"]

embedding_model_id         = "amazon.titan-embed-text-v2:0"
embedding_dimensions       = 1024
vector_index_name          = "bedrock-index"
enable_customer_managed_kms = true
chunking_strategy           = "FIXED_SIZE"
data_deletion_policy        = "DELETE"
