# AWS region. Authentication is supplied through the standard AWS credential chain.
region = "us-east-1"

# Remote state created by bootstrap/backend-bootstrap.
state_bucket_name = "replace-with-terraform-state-bucket"
state_region      = "us-east-1"
state_key_prefix  = "live/dev"

# Project
environment = "dev"
project     = "bedrock-kb"

# Vector Store Selection
vector_store_type       = "opensearch-serverless" # or "s3-vectors"
enable_standby_replicas = false
vector_index_name       = "bedrock-index"
